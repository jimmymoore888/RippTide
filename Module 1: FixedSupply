use near_sdk::{
    near_bindgen, env, AccountId, PanicOnDefault,
};
use near_sdk::borsh::{self, BorshDeserialize, BorshSerialize};

pub type Balance = u128;

// ===== CONSTANTS =====
pub const DECIMALS: u8 = 18;
pub const MAX_SUPPLY: Balance =
    10_000_000_000u128 * 10u128.pow(DECIMALS as u32);

#[near_bindgen]
#[derive(BorshDeserialize, BorshSerialize, PanicOnDefault)]
pub struct FixedSupply {
    /// Immutable maximum supply (10B)
    pub max_supply: Balance,

    /// Current circulating supply
    pub total_supply: Balance,

    /// Prevents re-initialization
    pub initialized: bool,

    /// Factory or deployer authority (genesis only)
    pub authority: AccountId,
}

#[near_bindgen]
impl FixedSupply {
    #[init]
    pub fn new(authority: AccountId) -> Self {
        Self {
            max_supply: MAX_SUPPLY,
            total_supply: 0,
            initialized: false,
            authority,
        }
    }

    /// ONE-TIME GENESIS MINT (must equal full supply)
    pub fn initialize_supply(&mut self) {
        assert_eq!(
            env::predecessor_account_id(),
            self.authority,
            "Unauthorized"
        );

        assert!(!self.initialized, "Already initialized");

        self.total_supply = self.max_supply;
        self.initialized = true;
    }

    /// SUPPLY CAN ONLY DECREASE (used after BurnCap validation)
    pub fn reduce_supply(&mut self, amount: Balance) {
        assert!(self.initialized, "Not initialized");
        assert!(amount > 0, "Amount must be > 0");
        assert!(
            self.total_supply >= amount,
            "Insufficient supply"
        );

        self.total_supply -= amount;
    }

    /// HARD BLOCK ANY MINT ATTEMPT
    pub fn mint(&self, _amount: Balance) {
        env::panic_str("Minting disabled: Fixed supply invariant");
    }

    /// VIEW: current supply
    pub fn get_total_supply(&self) -> Balance {
        self.total_supply
    }

    /// VIEW: max supply
    pub fn get_max_supply(&self) -> Balance {
        self.max_supply
    }
}
